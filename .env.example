# ============================================
# UYGULAMA
# ============================================
APP_ENV=production
LOG_LEVEL=INFO

# ============================================
# MATRIX
# ============================================
MATRIX_SERVER=http://localhost:8008
MATRIX_USER=@gitlab-bot:localhost
MATRIX_ACCESS_TOKEN=buraya_gercek_matrix_tokenini_yaz
ALLOWED_ROOM_NAMES=Üretim,üretim,Yazılım,yazılım,YAZILIM,Uretim_Test

# ============================================
# GITLAB
# ============================================
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=buraya_proje_id_yaz
GITLAB_TOKEN=buraya_gitlab_personal_access_token_yaz

# ============================================
# AI SERVİSLERİ
# ============================================
CLAUDE_API_KEY=buraya_anthropic_api_key_yaz
OPENAI_API_KEY=buraya_openai_api_key_yaz

# ============================================
# SES DEŞİFRE (Yerel Whisper)
# ============================================
WHISPER_MODEL=base
WHISPER_LANGUAGE=tr
# Sadece Windows'ta özel bir FFmpeg kurulum yolu varsa doldur, Linux'ta genelde gerekmez
FFMPEG_PATH=

# ============================================
# NODE.JS WEBHOOK KÖPRÜSÜ
# ============================================
NODEJS_WEBHOOK_URL=http://localhost:3000/api/v1/messages

# ============================================
# VERİTABANI
# ============================================
DB_NAME=bot_state.db

# ============================================
# ZAMAN DİLİMİ
# ============================================
TZ_OFFSET_HOURS=3
